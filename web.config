<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ============================================================
         TAF Modern — IIS Reverse Proxy Configuration
         Requires: ARR 3.0 + URL Rewrite 2.1 on IIS
         Node.js process must be running on localhost:3000 (via PM2)
         ============================================================ -->

    <rewrite>
      <rules>

        <!-- Rule 1: Serve Next.js static assets directly from disk (bypass Node.js) -->
        <rule name="StaticNextAssets" stopProcessing="true">
          <match url="^_next/static/(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Rule 2: Serve public folder static files directly from disk -->
        <rule name="PublicStaticFiles" stopProcessing="true">
          <match url="^(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Rule 3: Proxy all other requests to Next.js Node.js server -->
        <rule name="ReverseProxyToNextJS" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>

      </rules>
    </rewrite>

    <!-- Enable reverse proxy feature in ARR -->
    <proxy enabled="true" reverseRewriteHostInResponseHeaders="false" />

    <!-- Security Headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <!-- HSTS: 1 year, include subdomains. Remove 'preload' if subdomains aren't all HTTPS. -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
        <!-- CSP: unsafe-inline required for Next.js hydration scripts and Tailwind inline styles.
             Upgrade to nonce-based CSP when server-side nonce injection is available. -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=(), payment=()" />
        <remove name="X-Powered-By" />
        <remove name="Server" />
      </customHeaders>
    </httpProtocol>

    <!-- Cache static Next.js build assets aggressively (they are content-hashed) -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- Compress responses -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- Remove IIS server version header -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>

    <!-- Default document (optional, Next.js handles routing) -->
    <defaultDocument>
      <files>
        <clear />
      </files>
    </defaultDocument>

  </system.webServer>
</configuration>
